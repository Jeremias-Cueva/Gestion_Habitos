<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background_light">

    <TextView
        android:id="@+id/tvTitleRecuperar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar Contraseña"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvDescRecuperar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Ingresa tu correo electrónico y te enviaremos un código para restablecer tu contraseña.(Revisa en Spam)"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tvTitleRecuperar" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilEmailRecuperar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Correo electrónico"
        app:layout_constraintTop_toBottomOf="@id/tvDescRecuperar">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEmailRecuperar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:inputType="textEmailAddress" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnEnviarCodigo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Enviar Código"
        app:layout_constraintTop_toBottomOf="@id/tilEmailRecuperar" />

    <!-- Campo para el código -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCodigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Ingresa el código"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnEnviarCodigo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnVerificarCodigo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Verificar Código"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tilCodigo" />

    <!-- SECCIÓN PARA NUEVA CONTRASEÑA (Inicialmente oculta) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNuevaPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Nueva Contraseña"
        android:visibility="gone"
        app:passwordToggleEnabled="true"
        app:layout_constraintTop_toBottomOf="@id/btnVerificarCodigo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNuevaPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnGuardarNuevaPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Cambiar Contraseña"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tilNuevaPassword" />

</androidx.constraintlayout.widget.ConstraintLayout>