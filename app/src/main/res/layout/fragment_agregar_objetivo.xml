<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTituloVista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Objetivo"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etTituloObjetivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título del objetivo"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloVista" />

    <EditText
        android:id="@+id/etDescripcionObjetivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripción (opcional)"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etTituloObjetivo" />

    <EditText
        android:id="@+id/etMetaValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Meta numérica (ej. 100)"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etDescripcionObjetivo" />

</androidx.constraintlayout.widget.ConstraintLayout>