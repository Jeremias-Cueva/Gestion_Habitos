<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.gestionhabitos.view.fragments.LoginFragment"
        android:label="Iniciar Sesión"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_listaHabitosFragment"
            app:destination="@id/listaHabitosFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name ="com.example.gestionhabitos.view.fragments.DashboardFragment"
        android:label="Panel Principal"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/listaHabitosFragment"
        android:name="com.example.gestionhabitos.view.fragments.ListaHabitosFragment"
        android:label="Mis Hábitos"
        tools:layout="@layout/fragment_lista_habitos">
        <action
            android:id="@+id/action_listaHabitosFragment_to_agregarEditarHabitoFragment"
            app:destination="@id/agregarEditarHabitoFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/estadisticasFragment"
        android:name="com.example.gestionhabitos.view.fragments.EstadisticasFragment"
        android:label="Estadísticas"
        tools:layout="@layout/fragment_estadisticas" />

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.example.gestionhabitos.view.fragments.PerfilFragment"
        android:label="Mi Perfil"
        tools:layout="@layout/fragment_perfil">
        <action
            android:id="@+id/action_perfilFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/agregarEditarHabitoFragment"
        android:name="com.example.gestionhabitos.view.fragments.AgregarEditarHabitoFragment"
        android:label="Gestión de Hábito"
        tools:layout="@layout/fragment_agregar_editar_habito" />

</navigation>